{
  "name": "backend-node",
  "version": "1.0.0",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:dev:sanitize:dry": "node scripts/sanitize-delivery-db.js",
    "db:dev:sanitize:apply": "node scripts/sanitize-delivery-db.js --apply",
    "db:dev:sanitize:verify": "node scripts/sanitize-delivery-db.js --verify-only",
    "db:release:sanitize:apply": "node scripts/sanitize-delivery-db.js --apply --clear-catalogs --single-admin --normalize-core-ids",
    "db:release:sanitize:verify": "node scripts/sanitize-delivery-db.js --verify-only --clear-catalogs --single-admin --normalize-core-ids",
    "backup:test-auto": "node scripts/run-automated-backup.js",
    "backup:restore": "node scripts/restore-backup.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "dropbox": "^10.34.0",
    "express": "^5.2.1",
    "isomorphic-fetch": "^3.0.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "mysql2": "^3.17.4",
    "node-cron": "^4.2.1"
  }
}
